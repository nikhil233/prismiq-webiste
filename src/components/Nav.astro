---
import Button from './ui/Button.astro';
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-200"
>
  <div class="content-width flex items-center h-16 px-6">
    <a href="/" class="flex-1 text-xl font-bold text-[#1E40AF] tracking-tight">PrismIQ</a>

    <nav class="hidden md:flex items-center gap-8">
      {(['Product', 'Vision', 'For Teams', 'Design Partners'] as const).map(link => (
        <a
          href={`#${link.toLowerCase().replace(/\s+/g, '-')}`}
          class="text-sm text-[#64748B] hover:text-[#0F172A] transition-colors"
        >
          {link}
        </a>
      ))}
    </nav>

    <div class="flex-1 hidden md:flex justify-end">
      <Button href="#design-partner" variant="primary" class="text-sm">
        Join Waitlist
      </Button>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav.classList.add('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-[#E2E8F0]', 'shadow-sm');
    } else {
      nav.classList.remove('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-[#E2E8F0]', 'shadow-sm');
    }
  });
</script>
