---
const crmFields = [
  { label: 'Contact',       value: 'Rohit Sharma, VP Sales' },
  { label: 'Company',       value: 'Nexora Solutions' },
  { label: 'Deal Value',    value: '₹22,00,000' },
  { label: 'Stage',         value: 'Proposal Sent' },
  { label: 'Last Activity', value: '5 days ago' },
  { label: 'Owner',         value: 'Kavya R.' },
  { label: 'Next Step',     value: '' },
  { label: 'Notes',         value: 'Had a call, went well' },
  { label: 'Close Date',    value: 'Jun 30' },
];

const signals = [
  { src: 'Email',    icon: '📧', text: 'Pricing deck opened 3× on Jun 11 - 47 sec total view time', sev: 'warn' },
  { src: 'Email',    icon: '📧', text: 'CFO added to thread - new stakeholder not in CRM', sev: 'danger' },
  { src: 'CRM',      icon: '📊', text: 'Last rep email went unanswered - 4 days of silence', sev: 'danger' },
  { src: 'Meeting',  icon: '🎙', text: 'Competitor "Salesken" mentioned on Jun 9 meeting recording', sev: 'warn' },
];

const risks = [
  'No contact with decision-maker in 8 days',
  'Demo rescheduled twice - second no-show likely',
  'Proposal viewed once, less than 1 min total',
];

const actions = [
  { urgency: 'Today', text: 'Call Rohit - acknowledge CFO addition, ask for 3-way intro' },
  { urgency: 'By EOD', text: 'Send updated pricing with ROI calculator attached' },
];

const sources = [
  {
    icon: '📊',
    name: 'From CRM',
    signals: ['Stage velocity drift', 'Inactivity triggers', 'Close date slippage', 'Deal age tracking'],
    count: '4 signals this week',
  },
  {
    icon: '🎙',
    name: 'From Calls & Meetings',
    signals: ['Commitments extracted', 'Objections logged', 'Competitor mentions', 'Sentiment scoring'],
    count: '7 signals this week',
  },
  {
    icon: '📧',
    name: 'From Email & Docs',
    signals: ['Deck open events', 'Link-click patterns', 'Response-gap detection', 'Forwarding signals'],
    count: '5 signals this week',
  },
];
---

<section class="wtf-section" data-reveal>
  <div class="content-width">

    <div class="wtf-header reveal-item">
      <h2 class="wtf-h2">
        You don't have a data problem.<br />
        <span style="color:#1E40AF">You have an attention problem.</span>
      </h2>
      <p class="wtf-sub">
        Your CRM is full. Your calendar is full. The signal is buried in the noise.
        PrismIQ surfaces exactly what needs your attention - right now.
      </p>
    </div>

    <!-- Main comparison -->
    <div class="wtf-compare reveal-item" style="animation-delay:0.12s">

      <!-- Left: raw CRM record -->
      <div class="wtf-panel wtf-dim">
        <div class="wtf-panel-header">
          <span class="panel-eyebrow dim-eye">What your CRM shows</span>
          <span class="panel-badge dim-badge">Manual · Last updated 5d ago</span>
        </div>
        <div class="crm-record">
          {crmFields.map(f => (
            <div class={`crm-row${f.value === '' ? ' crm-empty' : ''}`}>
              <span class="crm-label">{f.label}</span>
              <span class="crm-value">{f.value === '' ? '(empty)' : f.value}</span>
            </div>
          ))}
        </div>
        <div class="panel-verdict dim-verdict">
          <span>😐</span>
          <span>You know a lot. You understand nothing actionable.</span>
        </div>
      </div>

      <!-- Divider -->
      <div class="wtf-vs">
        <div class="vs-line"></div>
        <div class="vs-pill">vs</div>
        <div class="vs-line"></div>
      </div>

      <!-- Right: PrismIQ intelligence -->
      <div class="wtf-panel wtf-bright">
        <div class="wtf-panel-header">
          <span class="panel-eyebrow bright-eye">What PrismIQ tells you</span>
          <span class="panel-badge bright-badge">Live</span>
        </div>

        <!-- Health score -->
        <div class="health-row">
          <div class="health-score-block">
            <span class="health-num">34</span>
            <span class="health-denom">/100</span>
          </div>
          <div class="health-right">
            <div class="health-top-row">
              <span class="health-label">Deal Health Score</span>
              <span class="health-tag">At Risk</span>
            </div>
            <div class="health-bar-wrap">
              <div class="health-bar-seg seg-red" style="width:34%"></div>
              <div class="health-bar-seg seg-empty"></div>
            </div>
            <div class="health-scale"><span>0</span><span>50</span><span>100</span></div>
          </div>
        </div>

        <!-- Signals -->
        <div class="pi-block">
          <div class="pi-block-title">Signals Detected <span class="pi-count">4</span></div>
          <div class="pi-signals">
            {signals.map(s => (
              <div class={`pi-signal pi-signal-${s.sev}`}>
                <span class={`pi-dot dot-${s.sev}`}></span>
                <span class="pi-sig-src">{s.src}</span>
                <span class="pi-sig-text">{s.text}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Commitment gap -->
        <div class="pi-block">
          <div class="pi-block-title">Open Commitment</div>
          <div class="pi-commit">
            <span class="commit-quote">"Send revised pricing by Wed"</span>
            <span class="commit-meta">Jun 10 · Kavya R.</span>
            <span class="commit-overdue">Overdue by 2 days</span>
          </div>
        </div>

        <!-- Risks + Actions side by side -->
        <div class="pi-two-col">
          <div class="pi-block">
            <div class="pi-block-title">Risk Factors</div>
            <ul class="pi-risks">
              {risks.map(r => <li>{r}</li>)}
            </ul>
          </div>
          <div class="pi-block">
            <div class="pi-block-title">Suggested Actions</div>
            <div class="pi-actions">
              {actions.map((a, i) => (
                <div class="pi-action">
                  <span class={`pi-action-urgency urg-${i === 0 ? 'high' : 'med'}`}>{a.urgency}</span>
                  <span class="pi-action-text">{a.text}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Signal sources strip -->
    <div class="sources-strip reveal-item" style="animation-delay:0.25s">
      <div class="sources-label">PrismIQ pulls signal from every layer of your stack</div>
      <div class="sources-grid">
        {sources.map(s => (
          <div class="source-card">
            <div class="source-top">
              <span class="source-icon">{s.icon}</span>
              <span class="source-name">{s.name}</span>
            </div>
            <ul class="source-signals">
              {s.signals.map(sig => <li>{sig}</li>)}
            </ul>
            <div class="source-count">{s.count}</div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .wtf-section { background: #F8FAFC; padding: 6rem 1.5rem; border-top: 1px solid #E2E8F0; }
  .wtf-header { max-width: 680px; margin-bottom: 3rem; }
  .wtf-h2 {
    font-size: clamp(1.85rem, 3.5vw, 2.75rem); font-weight: 700;
    letter-spacing: -0.02em; line-height: 1.15; color: #0F172A; margin: 0 0 1rem;
  }
  .wtf-sub { font-size: 1.05rem; color: #64748B; line-height: 1.65; margin: 0; }

  /* ── Compare grid ── */
  .wtf-compare {
    display: grid;
    grid-template-columns: 1fr 48px 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: 3rem;
  }

  .wtf-panel {
    border-radius: 18px; padding: 1.75rem;
    border: 1px solid #E2E8F0;
    display: flex; flex-direction: column; gap: 1.25rem;
  }
  .wtf-dim   { background: white; }
  .wtf-bright { background: white; }

  .wtf-panel-header { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .panel-eyebrow {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .dim-eye    { color: #94A3B8; }
  .bright-eye { color: #0F172A; }
  .panel-badge {
    font-size: 0.68rem; font-weight: 600; padding: 2px 8px; border-radius: 99px;
  }
  .dim-badge    { background: #F1F5F9; color: #94A3B8; }
  .bright-badge { background: #F1F5F9; color: #475569; }

  /* CRM record */
  .crm-record { display: flex; flex-direction: column; gap: 0; }
  .crm-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 6px 0; border-bottom: 1px solid #F1F5F9; gap: 12px;
  }
  .crm-row:last-child { border-bottom: none; }
  .crm-label { font-size: 0.72rem; font-weight: 600; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }
  .crm-value { font-size: 0.82rem; color: #475569; text-align: right; }
  .crm-empty .crm-value { color: #CBD5E1; font-style: italic; }

  /* Health score */
  .health-row {
    display: flex; align-items: center; gap: 14px;
    background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 10px; padding: 12px 14px;
  }
  .health-score-block { display: flex; align-items: baseline; gap: 2px; flex-shrink: 0; }
  .health-num  { font-size: 2rem; font-weight: 800; color: #EF4444; line-height: 1; letter-spacing: -0.04em; }
  .health-denom { font-size: 0.78rem; font-weight: 500; color: #94A3B8; }
  .health-right { flex: 1; display: flex; flex-direction: column; gap: 5px; }
  .health-top-row { display: flex; align-items: center; justify-content: space-between; }
  .health-label { font-size: 0.75rem; font-weight: 600; color: #475569; }
  .health-tag { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; background: #FEF2F2; color: #DC2626; padding: 2px 7px; border-radius: 4px; }
  .health-bar-wrap { display: flex; height: 6px; background: #E2E8F0; border-radius: 99px; overflow: hidden; }
  .health-bar-seg { height: 100%; }
  .seg-red   { background: linear-gradient(90deg, #EF4444, #F97316); }
  .seg-empty { flex: 1; }
  .health-scale { display: flex; justify-content: space-between; font-size: 0.6rem; color: #CBD5E1; }

  /* PI blocks */
  .pi-block { display: flex; flex-direction: column; gap: 7px; }
  .pi-block-title {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #94A3B8;
    display: flex; align-items: center; gap: 6px;
  }
  .pi-count {
    background: #E2E8F0; color: #64748B; font-size: 0.6rem; font-weight: 700;
    padding: 1px 5px; border-radius: 99px;
  }

  .pi-signals { display: flex; flex-direction: column; }
  .pi-signal {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 0; border-bottom: 1px solid #F1F5F9; font-size: 0.8rem; line-height: 1.45;
  }
  .pi-signal:last-child { border-bottom: none; }
  .pi-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .dot-danger { background: #EF4444; }
  .dot-warn   { background: #F59E0B; }
  .pi-sig-src {
    font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    white-space: nowrap; flex-shrink: 0; min-width: 32px;
  }
  .pi-signal-danger .pi-sig-src { color: #EF4444; }
  .pi-signal-warn   .pi-sig-src { color: #F59E0B; }
  .pi-sig-text { color: #334155; }

  .pi-commit {
    border-left: 3px solid #F59E0B; background: #FFFBEB;
    border-radius: 0 8px 8px 0; padding: 9px 12px;
    display: flex; flex-direction: column; gap: 3px;
  }
  .commit-quote   { font-size: 0.82rem; font-weight: 500; color: #334155; }
  .commit-meta    { font-size: 0.7rem; color: #94A3B8; }
  .commit-overdue { font-size: 0.7rem; font-weight: 700; color: #D97706; }

  .pi-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .pi-risks { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  .pi-risks li {
    font-size: 0.78rem; color: #475569; padding: 5px 0 5px 13px; position: relative; line-height: 1.45;
    border-bottom: 1px solid #F1F5F9;
  }
  .pi-risks li:last-child { border-bottom: none; }
  .pi-risks li::before { content: ''; width: 5px; height: 5px; background: #FCA5A5; border-radius: 50%; position: absolute; left: 0; top: 11px; }

  .pi-actions { display: flex; flex-direction: column; gap: 6px; }
  .pi-action { display: flex; flex-direction: column; gap: 2px; padding: 6px 8px; border-radius: 6px; background: #F8FAFC; border: 1px solid #E2E8F0; }
  .pi-action-urgency {
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
  }
  .urg-high { color: #EF4444; }
  .urg-med  { color: #F59E0B; }
  .pi-action-text { font-size: 0.76rem; color: #334155; line-height: 1.4; }

  .panel-verdict {
    display: flex; gap: 0.5rem; align-items: center;
    font-size: 0.8rem; font-weight: 600; padding: 0.65rem 0.9rem; border-radius: 9px;
  }
  .dim-verdict { background: #F1F5F9; color: #64748B; }

  /* VS divider */
  .wtf-vs { display: flex; flex-direction: column; align-items: center; padding-top: 2.5rem; gap: 6px; }
  .vs-line { flex: 1; width: 1px; background: #E2E8F0; min-height: 40px; }
  .vs-pill {
    width: 34px; height: 34px; border-radius: 50%; background: white;
    border: 1px solid #E2E8F0; display: flex; align-items: center; justify-content: center;
    font-size: 0.68rem; font-weight: 700; color: #94A3B8;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06); flex-shrink: 0;
  }

  /* ── Signal sources strip ── */
  .sources-strip {
    background: white; border: 1px solid #E2E8F0; border-radius: 18px; padding: 1.75rem;
  }
  .sources-label {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    color: #94A3B8; margin-bottom: 1.25rem; text-align: center;
  }
  .sources-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .source-card {
    background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 12px; padding: 1.1rem 1.25rem;
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .source-top { display: flex; align-items: center; gap: 8px; }
  .source-icon { font-size: 1.1rem; }
  .source-name { font-size: 0.85rem; font-weight: 700; color: #0F172A; }
  .source-signals {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 4px;
  }
  .source-signals li {
    font-size: 0.78rem; color: #64748B; padding-left: 12px; position: relative; line-height: 1.4;
  }
  .source-signals li::before { content: ''; width: 4px; height: 4px; background: #CBD5E1; border-radius: 50%; position: absolute; left: 1px; top: 6px; }
  .source-count {
    font-size: 0.72rem; font-weight: 700; color: #1E40AF;
    background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 99px;
    padding: 3px 10px; align-self: flex-start;
  }

  /* Reveal */
  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .wtf-section { padding: 4.5rem 1.25rem; }
    .wtf-compare { grid-template-columns: 1fr; gap: 1rem; }
    .wtf-vs { flex-direction: row; padding-top: 0; }
    .vs-line { flex: 1; height: 1px; width: auto; min-height: unset; }
    .sources-grid { grid-template-columns: repeat(2, 1fr); }
    .pi-two-col { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .wtf-section { padding: 4rem 1rem; }
    .wtf-header { margin-bottom: 2rem; }
    .sources-grid { grid-template-columns: 1fr; }
    .pi-signals { overflow-x: visible; }
    .pi-signal { flex-wrap: wrap; }
    .health-row { flex-wrap: wrap; gap: 10px; }
    .wtf-panel { padding: 1.25rem; }
    .sources-strip { padding: 1.25rem; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => observer.observe(el));
</script>
