---
const left = [
  'Deal stage: Proposal',
  'Last activity: 8 days ago',
  'Owner: Sarah K.',
  'Value: $48,000',
  'Close date: Jun 30',
];
const right = [
  'Last call: Sarah promised a custom quote by Friday — never sent',
  'Competitor mentioned: prospect demoed a rival last week',
  'Decision maker changed: new CFO involved, not in CRM',
  'Sentiment: last 2 emails went unanswered',
  'Risk: High — 3 unanswered follow-ups in 9 days',
];
---

<section class="wtf-section" data-reveal>
  <div class="content-width">

    <div class="wtf-header reveal-item">
      <h2 class="wtf-h2">
        You don't have a data problem.<br />
        <span style="color:#1E40AF">You have an attention problem.</span>
      </h2>
      <p class="wtf-sub">
        Your CRM is full. Your calendar is full. The signal is buried in the noise.
        PrismIQ surfaces the signal.
      </p>
    </div>

    <div class="wtf-grid reveal-item" style="animation-delay:0.15s">
      <div class="wtf-card dim">
        <div class="wtf-card-label">What your CRM shows</div>
        <ul class="wtf-list">
          {left.map(item => (
            <li class="wtf-item dim-item">
              <span class="wtf-dash">—</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="wtf-verdict dim-verdict">
          <span>😐</span> You know a lot. You understand nothing.
        </div>
      </div>

      <div class="wtf-divider">
        <div class="vs-pill">vs</div>
      </div>

      <div class="wtf-card bright">
        <div class="wtf-card-label bright-label">What PrismIQ surfaces</div>
        <ul class="wtf-list">
          {right.map(item => (
            <li class="wtf-item bright-item">
              <span class="arrow">→</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="wtf-verdict bright-verdict">
          <span>⚡</span> Now you know exactly what to do next.
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .wtf-section {
    background: #F8FAFC;
    padding: 6rem 1.5rem;
    border-top: 1px solid #E2E8F0;
  }
  .wtf-header { max-width: 640px; margin-bottom: 3rem; }
  .wtf-h2 {
    font-size: clamp(1.85rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #0F172A;
    margin: 0 0 1rem;
  }
  .wtf-sub { font-size: 1.1rem; color: #64748B; line-height: 1.6; margin: 0; }

  .wtf-grid {
    display: grid;
    grid-template-columns: 1fr 40px 1fr;
    gap: 0;
    align-items: start;
  }

  .wtf-card {
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid #E2E8F0;
  }
  .wtf-card.dim { background: white; }
  .wtf-card.bright { background: #EFF6FF; border-color: #BFDBFE; }

  .wtf-card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94A3B8;
    margin-bottom: 1.25rem;
  }
  .bright-label { color: #1E40AF; }

  .wtf-list { list-style: none; padding: 0; margin: 0 0 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .wtf-item { display: flex; gap: 0.6rem; font-size: 0.875rem; line-height: 1.5; align-items: flex-start; }
  .dim-item { color: #94A3B8; }
  .bright-item { color: #1E3A8A; }
  .wtf-dash { color: #CBD5E1; flex-shrink: 0; }
  .arrow { color: #1E40AF; flex-shrink: 0; font-weight: 600; }

  .wtf-verdict {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
  }
  .dim-verdict { background: #F1F5F9; color: #64748B; }
  .bright-verdict { background: #DBEAFE; color: #1E40AF; }

  .wtf-divider {
    display: flex;
    justify-content: center;
    padding-top: 2.5rem;
  }
  .vs-pill {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: white;
    border: 1px solid #E2E8F0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: #94A3B8;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => observer.observe(el));
</script>
