---
const days = [
  {
    name: 'Mon',
    events: [
      { time: '9:00 AM', title: 'Indus Fintech gone cold', detail: 'No activity in 12 days - nobody flagged it', type: 'danger' },
      { time: '2:00 PM', title: 'Quote sent, no reply',   detail: 'Proposal from last week - no follow-up nudge', type: 'warn' },
    ],
  },
  {
    name: 'Tue',
    events: [
      { time: '10:00 AM', title: 'Nexora demo went well',   detail: 'But decision-maker still not looped in', type: 'warn' },
      { time: '3:00 PM',  title: 'Pricing deck viewed 3×',  detail: 'No alert triggered - rep has no idea', type: 'danger' },
    ],
  },
  {
    name: 'Wed',
    events: [
      { time: '9:30 AM', title: 'Kalpana no-show (again)', detail: 'Second reschedule - deal quietly stalling', type: 'danger' },
      { time: '1:00 PM', title: 'Legal blocks deal',        detail: 'Champion went silent - not tracked anywhere', type: 'danger' },
    ],
  },
  {
    name: 'Thu',
    events: [
      { time: '11:00 AM', title: '5 follow-ups overdue',  detail: 'All committed on calls - never sent', type: 'danger' },
      { time: '2:30 PM',  title: '2h on forecast prep',   detail: 'Manual CRM export - still mostly guesswork', type: 'warn' },
    ],
  },
  {
    name: 'Fri',
    events: [
      { time: '3:00 PM', title: 'Pipeline review meeting', detail: '"How\'s the quarter?" - answered with a gut feel', type: 'warn' },
      { time: '5:00 PM', title: '₹2.8Cr at risk, unseen', detail: 'Week ends. No one knew. Monday will be worse.', type: 'danger' },
    ],
  },
];

const stats = [
  { num: '30%',   label: 'deals go dark',           sub: 'No activity 10+ days, zero alerts' },
  { num: '47%',   label: 'follow-ups never sent',  sub: 'Promised on calls, never actioned' },
  { num: '₹2.8Cr', label: 'at risk, invisible',   sub: 'Not tracked, not visible to anyone' },
  { num: '2h+',   label: 'wasted on forecasting',  sub: 'Manual exports, stale by Tuesday' },
];

const pains = [
  {
    icon: '🌑',
    title: 'Deals going dark',
    desc: "3 of your top opportunities haven't been touched in 10 days. Nobody flagged it.",
    detail: 'Average deal goes cold 8 days after last contact with no CRM alert.',
    freq: '3× this week',
    accent: '#EF4444',
    tag: 'Revenue at Risk',
    tagColor: 'red',
  },
  {
    icon: '📭',
    title: 'Missed follow-ups',
    desc: 'The rep meant to send that email. They got busy. The prospect moved on.',
    detail: '68% of lost deals had a missed commitment within the last 5 days of activity.',
    freq: 'Every week',
    accent: '#F59E0B',
    tag: 'Happens Every Week',
    tagColor: 'amber',
  },
  {
    icon: '🙈',
    title: 'Flying blind into calls',
    desc: "CRM shows the stage. Not what was promised on the last call - or what they're worried about.",
    detail: 'Reps spend avg 18 min re-reading notes before each call. Still miss key context.',
    freq: 'Every call',
    accent: '#EF4444',
    tag: 'Kills Momentum',
    tagColor: 'red',
  },
  {
    icon: '🎲',
    title: 'Forecasting by gut',
    desc: "Your manager asks 'how's the quarter?' Your best answer is 'I think we're fine.'",
    detail: 'Sales forecast accuracy averages 46% without a structured signal layer.',
    freq: 'Every quarter',
    accent: '#F59E0B',
    tag: 'Costs Quarters',
    tagColor: 'amber',
  },
];
---

<section class="brutal-section" data-reveal>
  <div class="content-width brutal-inner">

    <div class="brutal-header reveal-item">
      <h2 class="brutal-h2">
        This is what your week<br />
        <span style="color: #1E40AF">actually looks like.</span>
      </h2>
    </div>

    <div class="">
    <!-- Week timeline -->
    <div class="week-grid reveal-item">
      {days.map(day => (
        <div class="wday">
          <div class="wday-label">{day.name}</div>
          <div class="wday-events">
            {day.events.map(ev => (
              <div class={`wev wev-${ev.type}`}>
                <span class="wev-time">{ev.time}</span>
                <span class="wev-title">{ev.title}</span>
                <span class="wev-detail">{ev.detail}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="brutal-bridge reveal-item">Every sales team we talk to recognises all four of these. Every single one.</p>

    <!-- Pain stats -->
    <div class="pstats reveal-item">
      {stats.map(s => (
        <div class="pstat">
          <span class="pstat-num">{s.num}</span>
          <span class="pstat-label">{s.label}</span>
          <span class="pstat-sub">{s.sub}</span>
        </div>
      ))}
    </div>

    <!-- Bridge line -->

    <!-- Pain cards -->
    <div class="brutal-grid">
      {pains.map((p, i) => (
        <div
          class="pain-card reveal-item"
          style={`--accent: ${p.accent}; animation-delay: ${0.05 + i * 0.08}s`}
        >
          <div class="pain-top">
            <span class="pain-icon">{p.icon}</span>
            <span class={`pain-tag ${p.tagColor}`}>{p.tag}</span>
          </div>
          <h3 class="pain-title">{p.title}</h3>
          <p class="pain-desc">{p.desc}</p>
          <p class="pain-detail">{p.detail}</p>
          <div class="pain-footer">
            <span class="pain-freq">{p.freq}</span>
          </div>
          <div class="pain-accent-bar"></div>
        </div>
      ))}
    </div>
    </div><!-- /brutal-board -->

  </div>
</section>

<style>
  .brutal-section {
    background: white;
    padding: 6rem 1.5rem;
    border-top: 1px solid #E2E8F0;
  }
  .brutal-inner { max-width: 1280px; margin: auto; }

  .brutal-board {
    border: 1px solid #E2E8F0;
    border-radius: 20px;
    padding: 1.5rem;
  }

  .brutal-header { max-width: 640px; margin-bottom: 3rem; }
  .brutal-h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700; line-height: 1.15;
    letter-spacing: -0.02em; color: #0F172A; margin: 0 0 0.5rem;
  }
  .brutal-sub { font-size: 1.1rem; color: #64748B; line-height: 1.6; margin: 0; }
  .brutal-bridge {
    font-size: 0.88rem; color: #94A3B8; line-height: 1.6;
    margin: -1.5rem 0 1.5rem;
    padding-left: 2px;
  }

  /* ── Week timeline ── */
  .week-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin-bottom: 3rem;
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 20px;
    padding: 20px;
  }
  .wday { display: flex; flex-direction: column; gap: 8px; }
  .wday-label {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: #94A3B8;
    padding-bottom: 8px; border-bottom: 1px solid #E2E8F0;
    margin-bottom: 2px;
  }
  .wday-events { display: flex; flex-direction: column; gap: 7px; }

  .wev {
    border-radius: 10px; padding: 9px 11px;
    display: flex; flex-direction: column; gap: 2px;
    border: 1px solid #E2E8F0;
  }
  .wev-danger { background: #FEF2F2; }
  .wev-warn   { background: #FFFBEB; }
  .wev-time {
    font-size: 0.65rem; font-weight: 600;
    color: #94A3B8; letter-spacing: 0.03em;
  }
  .wev-title {
    font-size: 0.78rem; font-weight: 700;
    color: #0F172A; line-height: 1.3;
  }
  .wev-detail {
    font-size: 0.7rem; color: #64748B; line-height: 1.4; margin-top: 1px;
  }

  /* ── Pain stats row ── */
  .pstats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: #E2E8F0;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .pstat {
    background: white;
    padding: 1.5rem 1.75rem;
    display: flex; flex-direction: column; gap: 4px;
  }
  .pstat-num {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800; color: #EF4444;
    letter-spacing: -0.03em; line-height: 1;
  }
  .pstat-label {
    font-size: 0.9rem; font-weight: 600; color: #0F172A;
  }
  .pstat-sub { font-size: 0.78rem; color: #94A3B8; line-height: 1.4; }

  /* ── Pain cards ── */
  .brutal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .pain-card {
    background: #F8FAFC; border: 1px solid #E2E8F0;
    border-radius: 16px; padding: 1.5rem;
    position: relative; overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex; flex-direction: column; gap: 0;
  }
  .pain-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.07);
  }
  .pain-accent-bar {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px; background: var(--accent);
    border-radius: 0 0 16px 16px;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s ease;
  }
  .pain-card:hover .pain-accent-bar { transform: scaleX(1); }

  .pain-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1rem;
  }
  .pain-icon { font-size: 1.75rem; }
  .pain-tag {
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.06em; padding: 3px 8px; border-radius: 99px;
  }
  .pain-tag.red   { background: #F1F5F9; color: #475569; }
  .pain-tag.amber { background: #F1F5F9; color: #475569; }
  .pain-title { font-size: 1.05rem; font-weight: 700; color: #0F172A; margin: 0 0 0.5rem; }
  .pain-desc  { font-size: 0.88rem; color: #64748B; line-height: 1.6; margin: 0 0 0.75rem; }
  .pain-detail {
    font-size: 0.8rem; color: #94A3B8; line-height: 1.55;
    border-top: 1px solid #E2E8F0; padding-top: 0.75rem; margin: 0 0 0.75rem;
  }
  .pain-footer { margin-top: auto; }
  .pain-freq {
    display: inline-block; font-size: 0.72rem; font-weight: 600;
    background: #F1F5F9; color: #475569;
    padding: 3px 9px; border-radius: 99px;
  }

  /* Scroll reveal */
  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }
  .pain-card.visible { opacity: 1; }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .pstats    { grid-template-columns: repeat(2, 1fr); }
    .brutal-grid { grid-template-columns: repeat(2, 1fr); }

    /* horizontal scroll instead of truncating */
    .week-grid {
      grid-template-columns: repeat(5, minmax(150px, 1fr));
      overflow-x: auto;
      padding: 16px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .brutal-section { padding: 4rem 1rem; }
    .brutal-header  { margin-bottom: 2rem; }

    .week-grid {
      grid-template-columns: repeat(5, 180px);
      gap: 8px;
      padding: 14px;
      border-radius: 14px;
      margin-bottom: 1.75rem;
    }
    .wev { padding: 7px 9px; }
    .wev-title  { font-size: 0.72rem; }
    .wev-detail { font-size: 0.65rem; }

    .pstats { grid-template-columns: repeat(2, 1fr); margin-bottom: 1.75rem; }
    .pstat  { padding: 1rem 1rem; }
    .pstat-label { font-size: 0.8rem; }
    .pstat-sub   { font-size: 0.7rem; }

    .brutal-bridge { margin: 0 0 1.5rem; }

    .brutal-grid { grid-template-columns: 1fr; gap: 0.875rem; }
    .pain-card   { padding: 1.25rem; }
    .pain-title  { font-size: 0.95rem; }
    .pain-desc   { font-size: 0.83rem; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => observer.observe(el));
</script>
