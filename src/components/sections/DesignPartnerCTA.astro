---
const benefits = [
  'Free access during the design partner phase',
  'Weekly calls directly with the founders',
  'Your use cases shape the product roadmap',
  'Founder pricing locked in when we launch',
];
---

<section id="design-partner" class="cta-section" data-reveal>
  <div class="content-width cta-inner">

    <div class="cta-left reveal-item">
      <span class="cta-spots">20 spots · <strong>14 remaining</strong></span>
      <h2 class="cta-h2">
        You don't get handed a roadmap.<br />You write it.
      </h2>
      <p class="cta-sub">
        Design partners get early access, direct input into the product,
        and founder pricing - locked in for life.
      </p>
      <ul class="benefit-list">
        {benefits.map(b => (
          <li class="benefit-item">
            <span class="benefit-check">✓</span>
            {b}
          </li>
        ))}
      </ul>
    </div>

    <div class="cta-form-wrap reveal-item" style="animation-delay:0.15s">
      <form
        name="design-partner"
        class="cta-form"
        netlify
        data-netlify="true"
      >
        <h3 class="form-title">Join Waitlist</h3>

        <div class="form-row">
          <div class="form-field">
            <label class="form-label">First name</label>
            <input name="first" type="text" required placeholder="Sarah" class="form-input" />
          </div>
          <div class="form-field">
            <label class="form-label">Last name</label>
            <input name="last" type="text" required placeholder="Kim" class="form-input" />
          </div>
        </div>

        <div class="form-field">
          <label class="form-label">Work email</label>
          <input name="email" type="email" required placeholder="sarah@company.com" class="form-input" />
        </div>

        <div class="form-field">
          <label class="form-label">Phone number</label>
          <input name="phone" type="tel" required placeholder="+91 98765 43210" class="form-input" />
        </div>

        <div class="form-field">
          <label class="form-label">Company</label>
          <input name="company" type="text" required placeholder="Acme Inc." class="form-input" />
        </div>

        <div class="form-row">
          <div class="form-field">
            <label class="form-label">CRM you use</label>
            <select name="crm" class="form-input">
              <option value="">Select...</option>
              <option>HubSpot</option>
              <option>Zoho CRM</option>
              <option>Salesforce</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-field">
            <label class="form-label">Sales team size</label>
            <select name="team-size" class="form-input">
              <option value="">Select...</option>
              <option>1–5</option>
              <option>6–15</option>
              <option>16–50</option>
              <option>50+</option>
            </select>
          </div>
        </div>

        <button type="submit" class="form-submit">
          Join Waitlist →
        </button>

        <p class="form-note">No credit card. No commitment. We review every application personally.</p>
      </form>
    </div>

  </div>
</section>

<style>
  .cta-section {
    background: #1E40AF;
    padding: 6rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .cta-inner {
    max-width: 1280px;
    margin: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .cta-spots {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: rgba(255,255,255,0.12);
    color: white;
    padding: 5px 12px;
    border-radius: 99px;
    margin-bottom: 1.5rem;
  }
  .cta-spots strong { color: #FCD34D; }

  .cta-h2 {
    font-size: clamp(1.85rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: white;
    margin: 0 0 1rem;
  }
  .cta-sub { font-size: 1.05rem; color: #BFDBFE; line-height: 1.6; margin: 0 0 1.75rem; }

  .benefit-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: #BFDBFE;
  }
  .benefit-check {
    width: 20px; height: 20px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    color: #6EE7B7;
    font-size: 0.65rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cta-form-wrap {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
  }
  .form-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 1.5rem;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .form-field { display: flex; flex-direction: column; gap: 4px; margin-bottom: 0.75rem; }
  .form-label { font-size: 0.75rem; font-weight: 600; color: #64748B; }
  .form-input {
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.875rem;
    color: #0F172A;
    font-family: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
    background: white;
    width: 100%;
    box-sizing: border-box;
  }
  .form-input:focus {
    outline: none;
    border-color: #1E40AF;
    box-shadow: 0 0 0 3px rgba(30,64,175,0.1);
  }

  .form-submit {
    width: 100%;
    background: #1E40AF;
    color: white;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    padding: 12px;
    cursor: pointer;
    transition: background 0.15s;
    margin-top: 0.5rem;
  }
  .form-submit:hover { background: #1e3a8a; }

  .form-note { font-size: 0.75rem; color: #94A3B8; text-align: center; margin: 0.75rem 0 0; }

  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .cta-section { padding: 4.5rem 1.25rem; }
    .cta-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  @media (max-width: 640px) {
    .cta-section { padding: 4rem 1rem; }
    .cta-inner { gap: 2rem; }
    .form-row { grid-template-columns: 1fr; }
    .cta-form-wrap { padding: 1.5rem; border-radius: 16px; }
    .cta-h2 { font-size: 1.75rem; }
  }
</style>

<script>
  const o = new IntersectionObserver((e) => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); o.unobserve(x.target); } }); }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => o.observe(el));

  (() => {
    const form = document.querySelector('.cta-form') as HTMLFormElement | null;
    const btn  = form?.querySelector('.form-submit') as HTMLButtonElement | null;
    if (!form || !btn) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const get = (n: string) => (form.querySelector(`[name="${n}"]`) as HTMLInputElement | HTMLSelectElement)?.value.trim() ?? '';
      const email = get('email');
      const phone = get('phone');
      if (!email || !phone) return;
      btn.disabled = true;
      btn.textContent = 'Submitting...';
      try {
        await fetch('https://eo5hgc5lolylcki.m.pipedream.net', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            first_name:  get('first'),
            last_name:   get('last'),
            email,
            phone,
            company:     get('company'),
            crm:         get('crm'),
            team_size:   get('team-size'),
          }),
        });
        btn.textContent = '✓ Application received!';
        btn.style.background = '#059669';
        form.querySelectorAll('input, select').forEach((el) => {
          (el as HTMLInputElement | HTMLSelectElement).value = '';
        });
      } catch {
        btn.disabled = false;
        btn.textContent = 'Join Waitlist →';
      }
    });
  })();
</script>
