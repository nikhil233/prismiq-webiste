---
import Button from '../ui/Button.astro';
import Tag from '../ui/Tag.astro';

import hubspotSvg     from '../../../prismIQ/hubspot.svg?raw';
import zohoSvg        from '../../../prismIQ/ZOHO_logo_2023.svg?raw';
import zoomSvg        from '../../../prismIQ/zoom.svg?raw';
import slackSvg       from '../../../prismIQ/slack.svg?raw';
import gmailSvg       from '../../../prismIQ/gmail.svg?raw';
import Fireflies      from '../../../prismIQ/Fireflies.svg?raw';
import ReadAI         from '../../../prismIQ/ReadAI.svg?raw';
import otterRaw       from '../../../prismIQ/otter.svg?raw';
import leadsquaredRaw from '../../../prismIQ/leadsquared.svg?raw';
import salesforceRaw  from '../../../prismIQ/salesforce.svg?raw';
import fathomRaw      from '../../../prismIQ/Fathom.svg?raw';
import teamsRaw       from '../../../prismIQ/teams.svg?raw';

const PITCH = 78;
const OFFSET = 22;
const CY = 178; // i=2 * PITCH(78) + OFFSET(22) = SVG center (356px / 2)

const tools = [
  { name: 'Zoom',        svg: zoomSvg,         x: 147, y: 1,   fd: 4.1, fdd: 0.0 },
  { name: 'Slack',       svg: slackSvg,        x: 60,  y: 60,  fd: 4.4, fdd: 0.9 },
  { name: 'HubSpot',     svg: hubspotSvg,      x: 143, y: 188, fd: 4.2, fdd: 0.4 },
  { name: 'Read AI',     svg: ReadAI,          x: 145, y: 92,  fd: 3.9, fdd: 1.1 },
  { name: 'Fireflies',   svg: Fireflies,       x: 222, y: 68,  fd: 4.5, fdd: 0.6 },
  { name: 'Salesforce',  svg: salesforceRaw,   x: 228, y: 169, fd: 4.3, fdd: 1.4 },
  { name: 'Zoho CRM',    svg: zohoSvg,         x: 61,  y: 162, fd: 3.8, fdd: 0.3 },
  { name: 'Teams',       svg: teamsRaw,        x: 95,  y: 372, fd: 4.2, fdd: 1.0 },
  { name: 'Otter AI',    svg: otterRaw,        x: 205, y: 371, fd: 3.6, fdd: 0.8 },
  { name: 'Gmail',       svg: gmailSvg,        x: 55,  y: 266, fd: 3.7, fdd: 0.2 },
  { name: 'Fathom',      svg: fathomRaw,       x: 221, y: 267, fd: 4.0, fdd: 1.2 },
  { name: 'LeadSquared', svg: leadsquaredRaw,  x: 144, y: 284, fd: 4.6, fdd: 0.5 },
];

const pathD = (i: number) => {
  const y = i * PITCH + OFFSET;
  if (i === 2) return `M 0,${CY} L 112,${CY}`;
  return `M 0,${y} C 60,${y} 60,${CY} 112,${CY}`;
};
---

<section id="product" class="hero-section">
  <div class="dot-grid" aria-hidden="true"></div>
  <div class="content-width hero-inner">

    <div class="hero-copy">
      <div class="hero-tag anim-delay-1">
        <Tag color="blue">Revenue Execution Intelligence</Tag>
      </div>
      <h1 class="hero-h1 anim-delay-2">
        Your Entire Sales Stack.<br/>
        <span class="hero-blue">One Intelligence Engine.</span>
      </h1>
      <p class="hero-sub anim-delay-3">
        Lumo connects every tool your team uses, understands the signals,
        and tells you exactly what to do next.
      </p>
      <form class="hero-waitlist anim-delay-4" action="#design-partner">
        <input
          type="email"
          name="email"
          required
          placeholder="Enter your work email"
          class="waitlist-input"
        />
        <button type="submit" class="waitlist-btn">Join Waitlist →</button>
      </form>
      <p class="hero-note anim-delay-5">
        <span class="hero-check">✓</span> Free during beta &nbsp;·&nbsp;
        <span class="hero-check">✓</span> No credit card &nbsp;·&nbsp;
        <span class="hero-check">✓</span> First 20 Teams
      </p>
    </div>

    <div class="df-outer anim-delay-6">
      <div class="dataflow">

        <!-- Col 1: Tool chips -->
        <div class="tools-col">
          {tools.map((t, i) => (
            <div
              class="tool-chip"
              style={`left:${t.x}px;top:${t.y}px;animation:chipFadeIn 0.45s ease ${0.85 + i * 0.1}s forwards,floatChip ${t.fd}s ease-in-out ${t.fdd}s infinite`}
            >
              <span class="tool-icon tool-icon-svg" set:html={t.svg} />
              <span class="tool-name">{t.name}</span>
            </div>
          ))}
        </div>
        <div class="mobile-sep" aria-hidden="true">↓</div>

        <!-- Col 2: Converging arrows SVG -->
        <svg class="left-svg" width="120" height="356" viewBox="0 0 120 356" fill="none" aria-hidden="true">
          {tools.slice(0, 5).map((_, i) => (
            <path
              d={pathD(i)}
              stroke="#93C5FD"
              stroke-width="1.5"
              stroke-dasharray="5 4"
              fill="none"
              class="flow-path"
              style={`animation-delay:${i * 0.14}s`}
            />
          ))}
          <polygon points={`108,${CY - 4} 116,${CY} 108,${CY + 4}`} fill="#3B82F6" opacity="0.8" />
        </svg>

        <!-- Col 3: Engine card -->
        <div class="engine-wrap">
          <div class="pulse-ring ring-1"></div>
          <div class="pulse-ring ring-2"></div>
          <div class="pulse-ring ring-3"></div>
          <div class="engine-card">
            <div class="engine-header">
              <img src="/full-logo.svg" alt="Lumo" class="engine-full-logo" />
            </div>
            <div class="engine-orb">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="brain-hl" x1="10" y1="12" x2="32" y2="48" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#EFF6FF"/>
                    <stop offset="100%" stop-color="#BFDBFE"/>
                  </linearGradient>
                  <linearGradient id="brain-hr" x1="54" y1="12" x2="32" y2="48" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#DBEAFE"/>
                    <stop offset="100%" stop-color="#93C5FD" stop-opacity="0.55"/>
                  </linearGradient>
                  <path id="npl" d="M20 20 L14 30 L20 42"/>
                  <path id="npr" d="M44 20 L50 30 L44 42"/>
                </defs>
                <!-- Left hemisphere -->
                <path d="M32 12 C29 11 25 10 21 11.5 C16 13 12 17.5 10.5 23 C9 28.5 10 34.5 13 39 C16 43 21 46.5 27 47 L32 47 Z"
                      fill="url(#brain-hl)" stroke="#1E40AF" stroke-width="1.5" stroke-linejoin="round"/>
                <!-- Right hemisphere -->
                <path d="M32 12 C35 11 39 10 43 11.5 C48 13 52 17.5 53.5 23 C55 28.5 54 34.5 51 39 C48 43 43 46.5 37 47 L32 47 Z"
                      fill="url(#brain-hr)" stroke="#1E40AF" stroke-width="1.5" stroke-linejoin="round"/>
                <!-- Center fissure -->
                <line x1="32" y1="12" x2="32" y2="47" stroke="#93C5FD" stroke-width="0.75" stroke-dasharray="2 2.5"/>
                <!-- Left sulci -->
                <path d="M13 22 Q17.5 18 20.5 23" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                <path d="M11 32 Q16 27.5 18.5 33" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                <path d="M13 41 Q17 37.5 20 41.5" stroke="#1D4ED8" stroke-width="1.1" stroke-linecap="round" fill="none"/>
                <!-- Right sulci -->
                <path d="M51 22 Q46.5 18 43.5 23" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                <path d="M53 32 Q48 27.5 45.5 33" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                <path d="M51 41 Q47 37.5 44 41.5" stroke="#1D4ED8" stroke-width="1.1" stroke-linecap="round" fill="none"/>
                <!-- Neural connection lines -->
                <line x1="20" y1="20" x2="14" y2="30" stroke="#BFDBFE" stroke-width="0.8"/>
                <line x1="14" y1="30" x2="20" y2="42" stroke="#BFDBFE" stroke-width="0.8"/>
                <line x1="44" y1="20" x2="50" y2="30" stroke="#BFDBFE" stroke-width="0.8"/>
                <line x1="50" y1="30" x2="44" y2="42" stroke="#BFDBFE" stroke-width="0.8"/>
                <!-- Neural nodes -->
                <circle cx="20" cy="20" r="2.2" fill="#3B82F6" class="neural-dot" style="animation-delay:0s"/>
                <circle cx="14" cy="30" r="2.2" fill="#1E40AF" class="neural-dot" style="animation-delay:0.42s"/>
                <circle cx="20" cy="42" r="2" fill="#3B82F6" class="neural-dot" style="animation-delay:0.84s"/>
                <circle cx="44" cy="20" r="2.2" fill="#3B82F6" class="neural-dot" style="animation-delay:0.21s"/>
                <circle cx="50" cy="30" r="2.2" fill="#1E40AF" class="neural-dot" style="animation-delay:0.63s"/>
                <circle cx="44" cy="42" r="2" fill="#3B82F6" class="neural-dot" style="animation-delay:1.05s"/>
                <!-- Traveling signal - left side -->
                <circle r="1.8" fill="#60A5FA">
                  <animateMotion dur="2.2s" repeatCount="indefinite" begin="0s" calcMode="linear">
                    <mpath href="#npl"/>
                  </animateMotion>
                  <animate attributeName="opacity" values="0;0.95;0.95;0" keyTimes="0;0.08;0.88;1" dur="2.2s" repeatCount="indefinite"/>
                </circle>
                <!-- Traveling signal - right side -->
                <circle r="1.8" fill="#60A5FA">
                  <animateMotion dur="2.2s" repeatCount="indefinite" begin="1.1s" calcMode="linear">
                    <mpath href="#npr"/>
                  </animateMotion>
                  <animate attributeName="opacity" values="0;0.95;0.95;0" keyTimes="0;0.08;0.88;1" dur="2.2s" repeatCount="indefinite"/>
                </circle>
                <!-- Brain stem -->
                <path d="M27.5 47 C27 51.5 37 51.5 36.5 47" stroke="#1E40AF" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              </svg>
            </div>
            <p class="engine-title">Revenue Intelligence Engine</p>
            <div class="engine-pills">
              <span class="e-pill">Signal Detection</span>
              <span class="e-pill">Risk Scoring</span>
              <span class="e-pill">Next Actions</span>
            </div>
          </div>
        </div>
        <div class="mobile-sep" aria-hidden="true">↓</div>

        <!-- Col 4: Right arrow -->
        <svg class="right-svg" width="80" height="56" viewBox="0 0 80 56" fill="none" aria-hidden="true">
          <path d="M 0,28 L 66,28" stroke="#93C5FD" stroke-width="1.5" stroke-dasharray="5 4" fill="none" class="flow-path" />
          <polygon points="62,24 70,28 62,32" fill="#3B82F6" opacity="0.8" />
        </svg>

        <!-- Col 5: Output carousel -->
        <div class="oc-wrap" id="hero-oc" role="region" aria-label="Capability showcase">
          <div class="oc-track">

            <!-- Slide 0: Deal Intelligence -->
            <div class="oc-slide active">
              <div class="oc-header">
                <span class="oc-title">Deal Intelligence</span>
                <span class="oc-live">● Live</span>
              </div>
              <div class="oc-items">
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Indus Fintech</span>
                    <span class="oc-badge oc-red">At Risk</span>
                  </div>
                  <div class="oc-item-insight">No follow-up since quote sent Jun 4 - prospect going cold</div>
                  <div class="oc-item-action">→ Send a "still interested?" note today</div>
                </div>
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Nexora Solutions</span>
                    <span class="oc-badge oc-amber">Needs Attn</span>
                  </div>
                  <div class="oc-item-insight">Pricing deck opened 3× - decision-maker not yet looped in</div>
                  <div class="oc-item-action">→ Ask for intro to VP before end of week</div>
                </div>
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Kalpana Systems</span>
                    <span class="oc-badge oc-red">Stalled</span>
                  </div>
                  <div class="oc-item-insight">Champion went silent after legal review - 12 days no reply</div>
                  <div class="oc-item-action">→ Send ROI case study to re-engage legal team</div>
                </div>
              </div>
            </div>

            <!-- Slide 1: Commitment Tracker -->
            <div class="oc-slide">
              <div class="oc-header">
                <span class="oc-title">Commitment Tracker</span>
                <span class="oc-live oc-live-amber">● 2 Due Soon</span>
              </div>
              <div class="oc-items">
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Indus Fintech</span>
                    <span class="oc-badge oc-red">Overdue</span>
                  </div>
                  <div class="oc-item-insight">"You'll intro me to the CTO by Friday" - from Jun 12 call</div>
                  <div class="oc-item-action">→ Follow up on CTO introduction now</div>
                </div>
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Nexora Solutions</span>
                    <span class="oc-badge oc-amber">Due today</span>
                  </div>
                  <div class="oc-item-insight">"Send updated pricing within 3 days" - from Jun 10 call</div>
                  <div class="oc-item-action">→ Send revised quote before 5 PM</div>
                </div>
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Kalpana Systems</span>
                    <span class="oc-badge oc-green">On track</span>
                  </div>
                  <div class="oc-item-insight">"Pilot sign-off by Jun 20" - from Jun 9 call</div>
                  <div class="oc-item-action">→ Confirm pilot kickoff agenda for Jun 21</div>
                </div>
              </div>
            </div>

            <!-- Slide 2: Rep Performance & Coaching -->
            <div class="oc-slide">
              <div class="oc-header">
                <span class="oc-title">Rep Performance & Coaching</span>
                <span class="oc-week-badge">From this week's calls</span>
              </div>
              <div class="oc-items">
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Kavya R.</span>
                    <span class="oc-badge oc-amber">Coach</span>
                  </div>
                  <div class="oc-item-insight">Talk ratio 78% across 8 calls - not leaving room for prospect</div>
                  <div class="oc-item-action">→ Share active listening framework before next call</div>
                </div>
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Rohit M.</span>
                    <span class="oc-badge oc-green">Strong</span>
                  </div>
                  <div class="oc-item-insight">Best discovery questions on team - weak on closing sequences</div>
                  <div class="oc-item-action">→ Review closing scripts ahead of Kalpana call Friday</div>
                </div>
                <div class="oc-item">
                  <div class="oc-item-top">
                    <span class="oc-item-name">Sneha P.</span>
                    <span class="oc-badge oc-red">Gap</span>
                  </div>
                  <div class="oc-item-insight">No confirmed next step in 4 of 7 calls this week</div>
                  <div class="oc-item-action">→ Always lock a date before ending the call</div>
                </div>
              </div>
            </div>

          </div><!-- /oc-track -->

          <!-- Dot nav -->
          <div class="oc-dots">
            <button class="oc-dot active" data-idx="0" aria-label="Revenue Command Center"></button>
            <button class="oc-dot" data-idx="1" aria-label="Attention Engine"></button>
            <button class="oc-dot" data-idx="2" aria-label="Team Performance"></button>
          </div>
        </div>

      </div>

      <p class="df-status anim-delay-7">
        <span class="blink-dot"></span>
        Analyzing 47 signals from your stack right now
      </p>
    </div>

  </div>
</section>

<style>
  .hero-section {
    position: relative;
    padding-top: 7rem;
    padding-bottom: 5rem;
    overflow: hidden;
    background: white;
  }
  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(#DBEAFE 1px, transparent 0);
    background-size: 28px 28px;
    opacity: 0.6;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .hero-copy {
    text-align: center;
    max-width: 960px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .hero-tag  { opacity: 0; animation: fadeUp 0.5s ease forwards; }
  .hero-h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #0F172A;
    margin: 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards;
  }
  .hero-blue { color: #1E40AF; }
  .hero-sub {
    font-size: 1.15rem;
    color: #64748B;
    line-height: 1.65;
    max-width: 560px;
    margin: 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards;
  }
  .hero-waitlist {
    display: flex;
    align-items: center;
    gap: 6px;
    background: white;
    border: 1.5px solid #E2E8F0;
    border-radius: 14px;
    padding: 6px 6px 6px 18px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    width: 100%;
    max-width: 460px;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards;
  }
  .waitlist-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 14px;
    color: #0F172A;
    background: transparent;
    min-width: 0;
  }
  .waitlist-input::placeholder { color: #94A3B8; }
  .hero-waitlist:focus-within { animation: none; opacity: 1; transform: none; }
  .waitlist-btn {
    background: #1E40AF;
    color: white;
    border: none;
    border-radius: 10px;
    padding: 10px 20px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .waitlist-btn:hover { background: #1D3FA5; }
  .hero-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: #94A3B8;
    margin: 0;
    opacity: 0;
    animation: fadeUp 0.45s ease forwards;
  }
  .hero-check { color: #10B981; font-weight: 600; }

  .df-outer {
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    margin: 0 auto;
  }
  .dataflow {
    display: grid;
    grid-template-columns: 300px 130px 220px 80px 300px;
    align-items: center;
    gap: 0;
    width: 1080px;
    margin: 0 auto;
  }

  .tools-col {
    position: relative;
    height: 475px;
    width: 350px;
    flex-shrink: 0;
    overflow: visible;
  }
  .tool-chip {
    position: absolute;
    width: 84px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    padding: 12px 10px 10px;
    opacity: 0;
  }
  .tool-icon {
    width: 53px;
    height: 53px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tool-icon-svg {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    padding: 7px;
    overflow: hidden;
  }
  .tool-icon-svg > svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .tool-name {
    font-size: 11px;
    font-weight: 500;
    color: #475569;
    text-align: center;
    line-height: 1.25;
    white-space: normal;
  }

  .left-svg { align-self: center; overflow: visible; }
  .right-svg { align-self: center; }

  .flow-path { animation: dashFlow 2s linear infinite; }
  @keyframes dashFlow {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -27; }
  }

  .engine-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pulse-ring {
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    border: 1.5px solid rgba(59, 130, 246, 0.22);
    pointer-events: none;
    animation: pulseExpand 2.6s ease-out infinite;
  }
  .ring-1 { width: 168px; height: 168px; margin: -84px 0 0 -84px;   animation-delay: 0s; }
  .ring-2 { width: 210px; height: 210px; margin: -105px 0 0 -105px; animation-delay: 0.87s; }
  .ring-3 { width: 252px; height: 252px; margin: -126px 0 0 -126px; animation-delay: 1.74s; }
  @keyframes pulseExpand {
    0%   { opacity: 0.8; transform: scale(0.72); }
    100% { opacity: 0;   transform: scale(1.08); }
  }

  .engine-card {
    position: relative;
    z-index: 1;
    width: 174px;
    background: white;
    border: 2px solid #1E40AF;
    border-radius: 18px;
    padding: 16px 14px;
    text-align: center;
    box-shadow:
      0 0 0 4px rgba(30, 64, 175, 0.06),
      0 0 40px rgba(30, 64, 175, 0.18),
      0 8px 24px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .engine-header { display: flex; align-items: center; justify-content: center; }
  .engine-full-logo { height: 22px; width: auto; display: block; }
  .engine-orb {
    background: #EFF6FF; border: 1.5px solid #BFDBFE;
    border-radius: 50%; width: 80px; height: 80px;
    display: flex; align-items: center; justify-content: center;
  }
  .engine-title { font-size: 10.5px; font-weight: 600; color: #0F172A; line-height: 1.35; }
  .engine-pills { display: flex; flex-direction: column; gap: 4px; width: 100%; }
  .e-pill {
    font-size: 8.5px; font-weight: 500;
    background: #EFF6FF; color: #1E40AF;
    border: 1px solid #BFDBFE; border-radius: 99px;
    padding: 3px 8px; text-align: center; white-space: nowrap;
  }

  /* ---- Output carousel ---- */
  .oc-wrap {
    background: white;
    border: 1px solid #E2E8F0;
    border-radius: 14px;
    padding: 14px 14px 10px;
    box-shadow: 0 8px 32px rgba(30,64,175,0.10), 0 2px 8px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    animation: floatCard 4s ease-in-out infinite;
    min-width: 0;
  }
  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-5px); }
  }
  .oc-track { position: relative; flex: 1; }
  .oc-slide { display: none; flex-direction: column; gap: 8px; }
