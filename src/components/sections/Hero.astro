<script>
  // Lock waitlist form after its intro animation plays - prevents re-animation on focus/blur
  (() => {
    const form = document.querySelector('.hero-waitlist') as HTMLElement | null;
    if (!form) return;
    form.addEventListener('animationend', () => {
      form.style.opacity = '1';
      form.style.transform = 'none';
      form.style.animation = 'none';
    }, { once: true });
  })();

  // Waitlist form submission
  (() => {
    const form = document.querySelector('.hero-waitlist') as HTMLFormElement | null;
    const btn  = form?.querySelector('.waitlist-btn') as HTMLButtonElement | null;
    if (!form || !btn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (form.querySelector('.waitlist-input') as HTMLInputElement).value.trim();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = 'Joining...';

      try {
        await fetch('https://eo5hgc5lolylcki.m.pipedream.net', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        btn.textContent = '✓ You\'re on the list!';
        btn.style.background = '#059669';
        (form.querySelector('.waitlist-input') as HTMLInputElement).value = '';
      } catch {
        btn.disabled = false;
        btn.textContent = 'Join Waitlist →';
      }
    });
  })();

  (() => {
    const wrap = document.getElementById('hero-oc');
    if (!wrap) return;
    const slides = wrap.querySelectorAll('.oc-slide');
    const dots   = wrap.querySelectorAll('.oc-dot');
    let cur = 0, timer: ReturnType<typeof setInterval> | null = null;

    function goTo(n: number) {
      slides[cur].classList.remove('active');
      dots[cur].classList.remove('active');
      cur = ((n % slides.length) + slides.length) % slides.length;
      slides[cur].classList.add('active');
      dots[cur].classList.add('active');
    }
    function start() { timer = setInterval(() => goTo(cur + 1), 3500); }
    function stop()  { if (timer) clearInterval(timer); }

    dots.forEach((d, i) => d.addEventListener('click', () => { stop(); goTo(i); start(); }));
    wrap.addEventListener('mouseenter', stop);
    wrap.addEventListener('mouseleave', start);
    start();
  })();
</script>
