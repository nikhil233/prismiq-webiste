---
const stops = [
  {
    icon: '📞',
    text: 'Chasing reps for pipeline updates',
    replace: 'Deal status auto-surfaced in your morning digest — no rep input needed',
    impact: '2h saved / week',
  },
  {
    icon: '📝',
    text: 'Reading call transcripts to find what was promised',
    replace: 'Commitments auto-extracted from every recording, tracked until delivered',
    impact: '45 min saved / call',
  },
  {
    icon: '🎲',
    text: 'Guessing which deals need your attention',
    replace: 'Pipeline ranked by risk score — highest urgency always at the top',
    impact: 'Zero guesswork',
  },
  {
    icon: '💸',
    text: 'Losing deals that were never properly followed up',
    replace: 'Every missed follow-up flagged before the prospect goes cold',
    impact: '3 deals saved / quarter',
  },
  {
    icon: '📊',
    text: 'Building forecast spreadsheets that are wrong by Friday',
    replace: 'Signal-backed forecast updated every 6 hours — no manual export',
    impact: '67% faster forecast',
  },
  {
    icon: '🤷',
    text: 'Walking into QBRs without knowing why you lost',
    replace: 'Loss pattern analysis across calls, email, and CRM — ready before the meeting',
    impact: 'Full loss context',
  },
];
---

<section class="stop-section" data-reveal>
  <div class="content-width stop-inner">

    <div class="stop-left reveal-item">
      <h2 class="stop-h2">
        What happens when you finally<br />
        <span style="color:#1E40AF">have visibility.</span>
      </h2>
      <p class="stop-sub">
        Sales teams in early testing stopped doing all of these within the first two weeks.
      </p>
      <div class="stop-stats">
        <div class="stop-stat">
          <span class="stop-stat-num">6</span>
          <span class="stop-stat-label">activities eliminated</span>
        </div>
        <div class="stop-stat">
          <span class="stop-stat-num">14d</span>
          <span class="stop-stat-label">average time to value</span>
        </div>
      </div>
    </div>

    <ul class="stop-list">
      {stops.map((s, i) => (
        <li class="stop-item reveal-item" style={`animation-delay:${0.08 + i*0.07}s`}>
          <div class="stop-before">
            <span class="stop-icon">{s.icon}</span>
            <span class="stop-text">{s.text}</span>
          </div>
          <div class="stop-after">
            <span class="stop-arrow">→</span>
            <span class="stop-replace">{s.replace}</span>
            <span class="stop-impact">{s.impact}</span>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .stop-section { background: white; padding: 6rem 1.5rem; border-top: 1px solid #E2E8F0; }
  .stop-inner {
    max-width: 1280px; margin: auto;
    display: grid; grid-template-columns: 320px 1fr;
    gap: 4rem; align-items: start;
  }

  .stop-h2 {
    font-size: clamp(1.85rem, 3vw, 2.5rem);
    font-weight: 700; letter-spacing: -0.02em;
    line-height: 1.15; color: #0F172A; margin: 0 0 1rem;
  }
  .stop-sub { font-size: 0.95rem; color: #64748B; line-height: 1.6; margin: 0 0 2rem; }

  .stop-stats { display: flex; flex-direction: column; gap: 1px; background: #E2E8F0; border: 1px solid #E2E8F0; border-radius: 12px; overflow: hidden; }
  .stop-stat { background: white; padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 2px; }
  .stop-stat-num { font-size: 1.75rem; font-weight: 800; color: #059669; letter-spacing: -0.03em; line-height: 1; }
  .stop-stat-label { font-size: 0.75rem; color: #64748B; font-weight: 500; }

  /* List */
  .stop-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0; }

  .stop-item {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0; border-bottom: 1px solid #F1F5F9;
    transition: background 0.15s;
  }
  .stop-item:first-child { border-top: 1px solid #F1F5F9; }
  .stop-item:hover { background: #FAFBFF; }

  .stop-before {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px 16px 14px 0;
    border-right: 1px solid #F1F5F9;
  }
  .stop-icon { font-size: 0.95rem; flex-shrink: 0; margin-top: 1px; }
  .stop-text {
    font-size: 0.83rem; color: #475569; line-height: 1.5;
    text-decoration: line-through;
    text-decoration-color: #EF4444;
    text-decoration-thickness: 2px;
  }

  .stop-after {
    display: flex; align-items: flex-start; gap: 8px;
    padding: 14px 0 14px 16px;
  }
  .stop-arrow { font-size: 0.7rem; color: #059669; flex-shrink: 0; margin-top: 3px; font-weight: 700; }
  .stop-replace { font-size: 0.83rem; color: #334155; line-height: 1.5; flex: 1; }
  .stop-impact {
    font-size: 0.68rem; font-weight: 700; color: #059669;
    background: #F0FDF4; border: 1px solid #BBF7D0;
    padding: 2px 7px; border-radius: 4px;
    white-space: nowrap; align-self: flex-start; flex-shrink: 0; margin-top: 2px;
  }

  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .stop-section { padding: 4.5rem 1.25rem; }
    .stop-inner { grid-template-columns: 1fr; gap: 2rem; }
    .stop-item { grid-template-columns: 1fr; }
    .stop-before { border-right: none; border-bottom: 1px solid #F1F5F9; padding-bottom: 10px; }
    .stop-after { padding-top: 10px; }
  }

  @media (max-width: 640px) {
    .stop-section { padding: 4rem 1rem; }
    .stop-left { margin-bottom: 0; }
    .stop-stats { flex-direction: row; gap: 0; }
    .stop-impact { white-space: normal; }
  }
</style>

<script>
  const o = new IntersectionObserver((e) => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); o.unobserve(x.target); } }); }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => o.observe(el));
</script>
