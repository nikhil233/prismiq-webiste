---
const stops = [
  { text: 'Chasing reps for pipeline updates', icon: '📞' },
  { text: 'Reading call transcripts to find what was promised', icon: '📝' },
  { text: 'Guessing which deals need your attention', icon: '🎲' },
  { text: 'Losing deals that were never properly followed up', icon: '💸' },
  { text: 'Building forecast spreadsheets that are wrong by Friday', icon: '📊' },
  { text: 'Walking into QBRs without knowing why you lost', icon: '🤷' },
];
---

<section class="stop-section" data-reveal>
  <div class="content-width stop-inner">
    <div class="stop-left reveal-item">
      <h2 class="stop-h2">
        What happens when you finally<br />
        <span style="color:#1E40AF">have visibility.</span>
      </h2>
      <p class="stop-sub">
        Sales teams using PrismIQ in early testing stopped doing all of these within the first two weeks.
      </p>
      <div class="stop-stat">
        <div class="stop-stat-num">6</div>
        <div class="stop-stat-label">time-wasting activities<br />eliminated immediately</div>
      </div>
    </div>

    <ul class="stop-list">
      {stops.map((s, i) => (
        <li class="stop-item reveal-item" style={`animation-delay:${0.1 + i*0.08}s`}>
          <span class="stop-check">✓</span>
          <div class="stop-content">
            <span class="stop-emoji">{s.icon}</span>
            <span class="stop-text">{s.text}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .stop-section { background: white; padding: 6rem 1.5rem; border-top: 1px solid #E2E8F0; }
  .stop-inner {
    max-width: 1280px;
    margin: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .stop-h2 {
    font-size: clamp(1.85rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #0F172A;
    margin: 0 0 1rem;
  }
  .stop-sub { font-size: 1rem; color: #64748B; line-height: 1.6; margin: 0 0 2rem; }

  .stop-stat {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #F0FDF4;
    border: 1px solid #BBF7D0;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    width: fit-content;
  }
  .stop-stat-num { font-size: 2.5rem; font-weight: 800; color: #059669; line-height: 1; }
  .stop-stat-label { font-size: 0.8rem; color: #065F46; line-height: 1.4; }

  .stop-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }

  .stop-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    transition: transform 0.2s, border-color 0.2s;
  }
  .stop-item:hover { transform: translateX(4px); border-color: #BFDBFE; }

  .stop-check {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: #DCFCE7;
    color: #16A34A;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .stop-content { display: flex; align-items: center; gap: 0.6rem; }
  .stop-emoji { font-size: 1rem; flex-shrink: 0; }
  .stop-text { font-size: 0.9rem; color: #334155; text-decoration: line-through; text-decoration-color: #CBD5E1; }

  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const o = new IntersectionObserver((e) => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); o.unobserve(x.target); } }); }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => o.observe(el));
</script>
