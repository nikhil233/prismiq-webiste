---
import hubspotSvg     from '../../../prismIQ/hubspot.svg?raw';
import zohoSvg        from '../../../prismIQ/ZOHO_logo_2023.svg?raw';
import zoomSvg        from '../../../prismIQ/zoom.svg?raw';
import slackSvg       from '../../../prismIQ/slack.svg?raw';
import gmailSvg       from '../../../prismIQ/gmail.svg?raw';
import fireflyRaw     from '../../../prismIQ/Fireflies.svg?raw';
import readaiRaw      from '../../../prismIQ/ReadAI.svg?raw';
import otterRaw       from '../../../prismIQ/otter.svg?raw';
import leadsquaredRaw from '../../../prismIQ/leadsquared.svg?raw';
import salesforceRaw  from '../../../prismIQ/salesforce.svg?raw';
import fathomRaw      from '../../../prismIQ/Fathom.svg?raw';
import teamsRaw       from '../../../prismIQ/teams.svg?raw';

const logos = [
  { name: 'HubSpot',     svg: hubspotSvg },
  { name: 'Slack',       svg: slackSvg },
  { name: 'Zoho CRM',    svg: zohoSvg },
  { name: 'Gmail',       svg: gmailSvg },
  { name: 'Zoom',        svg: zoomSvg },
  { name: 'Fireflies',   svg: fireflyRaw },
  { name: 'Read AI',     svg: readaiRaw },
  { name: 'Otter AI',    svg: otterRaw },
  { name: 'LeadSquared', svg: leadsquaredRaw },
  { name: 'Salesforce',  svg: salesforceRaw },
  { name: 'Fathom',      svg: fathomRaw },
  { name: 'Teams',       svg: teamsRaw },
];
---

<section class="intbar">
  <p class="intbar-label">Plugs into the tools your team already uses</p>

  <div class="marquee">
    <div class="marquee-track">
      {[...logos, ...logos, ...logos, ...logos].map(l => (
        <div class="logo-chip">
          <span class="logo-icon" set:html={l.svg} />
          <span class="logo-name">{l.name}</span>
        </div>
      ))}
    </div>
  </div>

  <p class="intbar-sub">No new tools. No new process. PrismIQ reads the signals your team already creates.</p>
</section>

<style>
  .intbar {
    background: #F8FAFC;
    border-top: 1px solid #E2E8F0;
    border-bottom: 1px solid #E2E8F0;
    padding: 2.5rem 0;
    overflow: hidden;
  }

  .intbar-label {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94A3B8;
    margin: 0 0 1.75rem;
  }

  /* Marquee */
  .marquee {
    position: relative;
    overflow: hidden;
    /* fade edges */
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .logo-chip {
    display: flex;
    align-items: center;
    gap: 9px;
    background: white;
    border: 1px solid #E2E8F0;
    border-radius: 99px;
    padding: 8px 16px 8px 10px;
    white-space: nowrap;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    flex-shrink: 0;
    margin-right: 1.25rem;
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .logo-chip:hover {
    box-shadow: 0 4px 14px rgba(30,64,175,0.1);
    transform: translateY(-1px);
  }

  .logo-icon {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .logo-icon > svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .logo-name {
    font-size: 0.8rem;
    font-weight: 500;
    color: #334155;
  }

  /* Stats row */
  .intbar-sub {
    text-align: center;
    font-size: 0.82rem;
    color: #94A3B8;
    margin: 1.5rem 1.5rem 0;
    line-height: 1.5;
  }
</style>

<script>
  const marquee = document.querySelector('.marquee');
  const track   = marquee.querySelector('.marquee-track');

  let x      = 0;
  let paused = false;
  const speed = 0.5; // px per frame ≈ 30 px/s at 60 fps
  const half  = track.scrollWidth / 4;

  marquee.addEventListener('mouseenter', () => { paused = true;  });
  marquee.addEventListener('mouseleave', () => { paused = false; });

  (function loop() {
    if (!paused) {
      x -= speed;
      if (-x >= half) x += half;
      track.style.transform = `translateX(${x}px)`;
    }
    requestAnimationFrame(loop);
  })();
</script>
