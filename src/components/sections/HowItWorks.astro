---
import Button from '../ui/Button.astro';

import hubspotSvg     from '../../../prismIQ/hubspot.svg?raw';
import zohoSvg        from '../../../prismIQ/ZOHO_logo_2023.svg?raw';
import zoomSvg        from '../../../prismIQ/zoom.svg?raw';
import fireflyRaw     from '../../../prismIQ/Fireflies.svg?raw';
import slackSvg       from '../../../prismIQ/slack.svg?raw';
import gmailSvg       from '../../../prismIQ/gmail.svg?raw';
import readaiRaw      from '../../../prismIQ/ReadAI.svg?raw';
import otterRaw       from '../../../prismIQ/otter.svg?raw';
import leadsquaredRaw from '../../../prismIQ/leadsquared.svg?raw';
import salesforceRaw  from '../../../prismIQ/salesforce.svg?raw';
import fathomRaw      from '../../../prismIQ/Fathom.svg?raw';
import teamsRaw       from '../../../prismIQ/teams.svg?raw';

const tools = [
  { name: 'HubSpot',     svg: hubspotSvg },
  { name: 'Zoho CRM',    svg: zohoSvg    },
  { name: 'Salesforce',  svg: salesforceRaw },
  { name: 'Zoom',        svg: zoomSvg    },
  { name: 'Fireflies',   svg: fireflyRaw },
  { name: 'Otter AI',    svg: otterRaw   },
  { name: 'Fathom',      svg: fathomRaw  },
  { name: 'Slack',       svg: slackSvg   },
  { name: 'Gmail',       svg: gmailSvg   },
  { name: 'Read AI',     svg: readaiRaw  },
  { name: 'LeadSquared', svg: leadsquaredRaw },
  { name: 'Teams',       svg: teamsRaw   },
];

const steps = [
  {
    n: '01',
    time: '5 min setup',
    title: 'Connect your stack',
    desc: 'One-click OAuth for every tool your team already uses. No data migration. No IT tickets. No new process for reps.',
    bullets: [
      'We read your data - we never write to your CRM',
      'Works with existing HubSpot, Zoho, Salesforce setups',
      'Call recordings pulled automatically from Fireflies, Gong, Read AI',
      'Email & calendar connected via Gmail / Outlook OAuth',
    ],
    example: {
      label: 'Connected in this session',
      items: [
        { label: 'CRM records synced',    val: '1,247' },
        { label: 'Call recordings found', val: '84' },
        { label: 'Email threads indexed', val: '3,412' },
        { label: 'Open deals detected',   val: '31' },
      ],
    },
  },
  {
    n: '02',
    time: 'Updates in real-time',
    title: 'Lumo reads the signals',
    desc: 'Every deal gets a live timeline built from CRM events, call transcripts, email threads, and doc engagement - cross-referenced automatically.',
    bullets: [
      'Extracts commitments from every call recording',
      'Flags inactivity, sentiment shifts, and new stakeholders',
      'Scores each deal 0–100 across 6 risk dimensions',
      'Signals refresh in real-time as activity happens',
    ],
    example: {
      label: 'Signals detected on first run',
      items: [
        { label: 'At-risk deals flagged',    val: '7' },
        { label: 'Commitments extracted',    val: '23' },
        { label: 'Missed follow-ups found',  val: '11' },
        { label: 'New stakeholders spotted', val: '4' },
      ],
    },
  },
  {
    n: '03',
    time: 'Daily at 8 AM',
    title: 'Act on what matters',
    desc: "Every morning: your pipeline risk-ranked. Every deal: a specific next action. Every rep: a personalised briefing - before their first call.",
    bullets: [
      'Pipeline sorted by risk score - highest urgency first',
      'Per-rep morning briefing with ranked action items',
      'Commitment follow-up reminders tied to call dates',
      'Manager digest with forecast delta and team coaching flags',
    ],
    example: {
      label: "Kavya R. · Today's briefing",
      items: [
        { label: 'Deals needing action',  val: '3' },
        { label: 'Overdue commitments',   val: '2' },
        { label: 'New signals today', val: '5' },
        { label: 'Forecast confidence',   val: '74%' },
      ],
    },
  },
];

const trust = [
  { num: 'One-click', label: 'OAuth setup per tool',        sub: 'no IT tickets, no migration' },
  { num: '< 6h',   label: 'first at-risk deal flagged',   sub: 'from the moment you connect' },
  { num: 'Zero',   label: 'rep training required',        sub: 'briefing lands in their inbox' },
];
---

<section id="how-it-works" class="how-section" data-reveal>
  <div class="content-width">

    <div class="how-header reveal-item">
      <h2 class="how-h2">
        Connect your CRM.<br />
        <span style="color:#1E40AF">Know your pipeline in <span class="underline">minutes</span>.</span>
      </h2>
      <p class="how-sub">No implementation project. No consultants. No new process for your reps.</p>
    </div>

    <!-- Steps -->
    <div class="steps-grid">
      {steps.map((s, i) => (
        <div class="step-card reveal-item" style={`animation-delay:${0.08 + i*0.12}s`}>

          <div class="step-meta">
            <span class="step-num">{s.n}</span>
            <span class="step-time">{s.time}</span>
          </div>


          <div class="step-icon">{s.n === '01' ? '🔌' : s.n === '02' ? '🧠' : '🎯'}</div>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>

          <ul class="step-bullets">
            {s.bullets.map(b => <li>{b}</li>)}
          </ul>

          <div class="step-example">
            <div class="ex-label">{s.example.label}</div>
            <div class="ex-rows">
              {s.example.items.map(item => (
                <div class="ex-row">
                  <span class="ex-key">{item.label}</span>
                  <span class="ex-val">{item.val}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Connector arrows between steps -->
    <div class="step-connectors" aria-hidden="true">
      <div class="conn-line"></div>
      <div class="conn-arrow">→</div>
      <div class="conn-line"></div>
      <div class="conn-arrow">→</div>
      <div class="conn-line"></div>
    </div>

    <!-- Trust stats -->
    <div class="trust-row reveal-item" style="animation-delay:0.4s">
      {trust.map(t => (
        <div class="trust-stat">
          <span class="trust-num">{t.num}</span>
          <span class="trust-label">{t.label}</span>
          <span class="trust-sub">{t.sub}</span>
        </div>
      ))}
    </div>

    <div class="how-cta reveal-item" style="animation-delay:0.5s">
      <Button href="#design-partner" variant="primary">Join the Waitlist</Button>
    </div>

  </div>
</section>

<style>
  .how-section { background: #F8FAFC; padding: 6rem 1.5rem; border-top: 1px solid #E2E8F0; }
  .how-header { max-width: 600px; margin-bottom: 3rem; }
  .how-h2 {
    font-size: clamp(1.85rem, 3.5vw, 2.75rem); font-weight: 700;
    letter-spacing: -0.02em; line-height: 1.15; color: #0F172A; margin: 0 0 1rem;
  }
  .how-sub { font-size: 1.05rem; color: #64748B; margin: 0; }

  /* ── Steps ── */
  .steps-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .step-card {
    background: white; border: 1px solid #E2E8F0; border-radius: 18px;
    padding: 1.75rem; display: flex; flex-direction: column; gap: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.07); }

  .step-meta { display: flex; align-items: center; justify-content: space-between; }
  .step-num { font-size: 2.25rem; font-weight: 800; color: #E2E8F0; line-height: 1; }
  .step-time {
    font-size: 0.7rem; font-weight: 600; color: #64748B;
    background: #F1F5F9; border: 1px solid #E2E8F0;
    padding: 3px 10px; border-radius: 99px; white-space: nowrap;
  }

  /* Logo chips (step 1 only) */
  .step-logos { display: flex; flex-wrap: wrap; gap: 5px; }
  .step-logo-chip {
    display: flex; align-items: center; gap: 5px;
    background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 8px; padding: 4px 9px 4px 6px;
  }
  .step-logo-icon { width: 16px; height: 16px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .step-logo-icon > svg { width: 100%; height: 100%; display: block; }
  .step-logo-name { font-size: 0.7rem; font-weight: 600; color: #64748B; white-space: nowrap; }

  .step-icon { font-size: 1.5rem; }
  .step-title { font-size: 1.05rem; font-weight: 700; color: #0F172A; margin: 0; }
  .step-desc { font-size: 0.85rem; color: #64748B; line-height: 1.65; margin: 0; }

  .step-bullets {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 5px;
    border-top: 1px solid #F1F5F9; padding-top: 0.875rem;
  }
  .step-bullets li {
    font-size: 0.8rem; color: #475569; line-height: 1.5;
    padding-left: 14px; position: relative;
  }
  .step-bullets li::before { content: ''; width: 4px; height: 4px; background: #CBD5E1; border-radius: 50%; position: absolute; left: 1px; top: 7px; }

  .step-example {
    background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 12px;
    padding: 12px 14px; margin-top: auto;
    display: flex; flex-direction: column; gap: 8px;
  }
  .ex-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #94A3B8; }
  .ex-rows { display: flex; flex-direction: column; }
  .ex-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 5px 0; border-bottom: 1px solid #F1F5F9;
  }
  .ex-row:last-child { border-bottom: none; }
  .ex-key { font-size: 0.78rem; color: #64748B; }
  .ex-val { font-size: 0.82rem; font-weight: 700; color: #0F172A; }

  /* Connectors (decorative, desktop only) */
  .step-connectors {
    display: none; /* shown via JS trick if needed; hidden on small screens */
  }

  /* ── Trust stats ── */
  .trust-row {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: #E2E8F0;
    border: 1px solid #E2E8F0; border-radius: 14px; overflow: hidden;
    margin: 1.75rem 0 2.5rem;
  }
  .trust-stat {
    background: white; padding: 1.25rem 1.5rem;
    display: flex; flex-direction: column; gap: 3px;
  }
  .trust-num   { font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 800; color: #1E40AF; letter-spacing: -0.03em; line-height: 1; }
  .trust-label { font-size: 0.88rem; font-weight: 600; color: #0F172A; }
  .trust-sub   { font-size: 0.75rem; color: #94A3B8; }

  .how-cta { text-align: left; }

  .reveal-item { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal-item.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .how-section { padding: 4.5rem 1.25rem; }
    .steps-grid { grid-template-columns: 1fr; }
    .trust-row  { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .how-section { padding: 4rem 1rem; }
    .how-header { margin-bottom: 2rem; }
    .trust-row  { grid-template-columns: 1fr; }
    .step-logos { gap: 4px; }
    .step-card  { padding: 1.25rem; }
    .trust-stat { padding: 1rem; }
  }
</style>

<script>
  const o = new IntersectionObserver((e) => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); o.unobserve(x.target); } }); }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal] .reveal-item').forEach(el => o.observe(el));

  document.querySelector('#how-it-works a[href="#design-partner"]')?.addEventListener('click', () => {
    window.posthog?.capture('how_it_works_cta_clicked');
  });
</script>
