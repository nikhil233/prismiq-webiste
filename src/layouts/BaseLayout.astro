---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'PrismIQ - Revenue Execution Intelligence Platform',
  description = 'PrismIQ integrates with your CRM and call recordings to surface what your sales team needs to act on before deals slip.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://prismiq.com');

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "PrismIQ",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
